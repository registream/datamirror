# Logs
*.log
# ... except example and replication reference logs, which are committed as
# canonical evidence of a successful round trip.
!examples/*.log
!replication/*/modified/reference_*.log

# Stata temp files
*.smcl

# Test output (generated by test runs)
stata/tests/output/
stata/tests/logs/

# Replication run outputs (generated; see replication/<paper>/synthetic/ and RUN_RESULTS.txt)
replication/*/synthetic/
replication/*/RUN_RESULTS.txt

# UKHLS test data (restricted-licence download; fetched by user via
# examples/prepare_ukhls_simple.do, not committed to the repo)
stata/tests/data/*.dta

# OS files
.DS_Store
